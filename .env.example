MINTER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
WALLET_VERIFIER_DOMAIN="world-os"
WALLET_VERIFIER_VERSION="1"
