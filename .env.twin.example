# .env.twin.example — Environment template for the A2A_MCP Digital Twin stack
# Copy to .env.twin and fill in your values before running scripts/deploy-bot.sh

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=twin-pass-change-me
POSTGRES_DB=a2a_twin

# ─── AI / LLM ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=<your-gemini-api-key>
GEMINI_MODEL=gemini-1.5-pro

# ─── Deployment Bot ──────────────────────────────────────────────────────────
# Action for the bot container (full-deploy | deploy | monitor | status)
BOT_ACTION=monitor
HEALTH_CHECK_INTERVAL=30   # seconds between health polls
RECOVERY_ATTEMPTS=3        # restart retries per unhealthy service
RECOVERY_DELAY=10          # seconds between recovery attempts

# ─── WhatsApp Notifications (optional) ──────────────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_CHANNEL_ID=
