{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "agents"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "agent_id",
          "project_id",
          "vertical_id",
          "index_manifest_ref",
          "routing_policy_ref",
          "expert_catalog_ref",
          "allowed_experts",
          "prompt_contract",
          "owner_role",
          "capabilities",
          "tool_allowlist",
          "execution_environment"
        ],
        "properties": {
          "agent_id": {
            "type": "string"
          },
          "project_id": {
            "type": "string"
          },
          "vertical_id": {
            "type": "string"
          },
          "index_manifest_ref": {
            "type": "string"
          },
          "routing_policy_ref": {
            "type": "string"
          },
          "expert_catalog_ref": {
            "type": "string"
          },
          "allowed_experts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "prompt_contract": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "system_preamble_ref",
              "context_policy",
              "output_contract"
            ],
            "properties": {
              "system_preamble_ref": {
                "type": "string"
              },
              "context_policy": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "max_chunks",
                  "max_tokens"
                ],
                "properties": {
                  "max_chunks": {
                    "type": "integer"
                  },
                  "max_tokens": {
                    "type": "integer"
                  }
                }
              },
              "output_contract": {
                "type": "string"
              }
            }
          },
          "owner_role": {
            "type": "string",
            "minLength": 1
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "tool_allowlist": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "execution_environment": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "os",
              "shell"
            ],
            "properties": {
              "os": {
                "type": "string",
                "enum": [
                  "windows",
                  "linux",
                  "macos"
                ]
              },
              "shell": {
                "type": "string",
                "enum": [
                  "powershell",
                  "bash",
                  "zsh",
                  "cmd"
                ]
              },
              "constraints": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                },
                "uniqueItems": true
              }
            }
          }
        }
      }
    },
    "locked_at": {
      "type": "string",
      "format": "date-time"
    },
    "locked_by": {
      "type": "string",
      "minLength": 1
    }
  }
}
