{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "paths": {
      "@world-os/kernel": ["../kernel/src/index.ts"]
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*"]
}
