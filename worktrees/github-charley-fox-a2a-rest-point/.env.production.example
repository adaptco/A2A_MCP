# Production Environment - Kubernetes Secrets
# These are base64 encoded and stored in Kubernetes Secret: agent-runner-secrets
# Update these values and apply with:
# kubectl create secret generic agent-runner-secrets -n production \
#   --from-literal=DATABASE_URL="postgresql://..." \
#   --from-literal=REDIS_URL="redis://..." \
#   --from-literal=JWT_SECRET="..." \
#   --dry-run=client -o yaml | kubectl apply -f -

NODE_ENV=production
LOG_LEVEL=info
PORT=3000
HOST=0.0.0.0

# Database connection string (URL format for production)
# Use managed database service (RDS, Cloud SQL, etc.) for production
# DATABASE_URL=postgresql://user:password@prod-db-host:5432/agent_runner_prod

# Redis URL for production
# Use managed Redis service (ElastiCache, Cloud Memorystore, etc.)
# REDIS_URL=redis://:password@prod-redis-host:6379

# JWT secrets - Use strong, random values in production
# Generate with: openssl rand -base64 32
# JWT_SECRET=...
# REFRESH_TOKEN_SECRET=...

# Session configuration
SESSION_TIMEOUT=3600
COOKIE_SECURE=true
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=Strict

# CORS - Restrict to production domain
CORS_ORIGIN=https://example.com,https://api.example.com

# Rate limiting (requests per minute)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Security headers
HELMET_CONTENT_SECURITY_POLICY=true
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff
