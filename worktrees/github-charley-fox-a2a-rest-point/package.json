{
  "name": "container-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "Bootstrap entrypoint for the Container artifact workspace.",
  "scripts": {
    "start": "npm --prefix shared run dev -- --host 0.0.0.0",
    "build": "npm --prefix shared run build",
    "preview": "npm --prefix shared run preview -- --host 0.0.0.0",
    "type-check": "npm --prefix shared run type-check",
    "compose:up": "docker compose up --build",
    "validate:workflows": "python scripts/validate_workflows.py",
    "validate:runtime": "python scripts/validate_runtime_contract.py --agents Agents.md --workflow .github/workflows/deploy-pipeline.yml --workflow .github/workflows/docker-build-and-test.yml"
  }
}
