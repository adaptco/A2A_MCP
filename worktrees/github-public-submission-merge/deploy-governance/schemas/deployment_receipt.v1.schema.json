{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "deployment_receipt.v1.schema.json",
  "title": "Deployment Receipt v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "deployment_id",
    "ts_utc",
    "mode",
    "status",
    "inputs",
    "hashes",
    "images",
    "result"
  ],
  "properties": {
    "schema_version": { "const": "deployment.receipt.v1" },

    "deployment_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },

    "ts_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },

    "mode": { "enum": ["dry_run", "apply"] },

    "status": { "enum": ["success", "fail"] },

    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compose_file", "dockerfile_bot", "env_file"],
      "properties": {
        "compose_file": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "dockerfile_bot": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "env_file": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },

    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compose_sha256", "dockerfile_sha256", "env_sha256", "policy_sha256"],
      "properties": {
        "compose_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "dockerfile_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "env_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "policy_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },

    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "digest"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 256 },
          "digest": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      }
    },

    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exit_code", "summary"],
      "properties": {
        "exit_code": { "type": "integer", "minimum": 0, "maximum": 255 },
        "summary": { "type": "string", "minLength": 0, "maxLength": 4096 }
      }
    },

    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seal_phrase"],
      "properties": {
        "seal_phrase": { "type": "string", "const": "Canonical truth, attested and replayable." }
      }
    }
  }
}
