{
  "schema_version": "deploy.policy.v1",
  "tool_allowlist": [
    "docker",
    "docker compose",
    "python3"
  ],
  "env_handling": {
    "strategy": "redacted_key_value_hash",
    "key_pattern": "^[A-Z0-9_]+$"
  },
  "digest_binding": {
    "require_sha256_digests": true,
    "bind_services": "explicit"
  }
}
