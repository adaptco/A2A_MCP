{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://core-orchestrator/schemas/actuation_contract.defaults.v1.schema.json",
  "title": "Actuation Contract Defaults v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "actuation_payload_defaults",
    "cost_weights",
    "invariants"
  ],
  "$defs": {
    "required_check": {
      "type": "string",
      "enum": [
        "invariant-check",
        "lint-diff-build-test",
        "governance_check"
      ]
    },
    "invariant_registry_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "assertion"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "assertion": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "properties": {
    "actuation_payload_defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "trigger_reason",
        "mode",
        "policy_zone",
        "pr_template_id",
        "required_checks",
        "risk_profile"
      ],
      "properties": {
        "trigger_reason": {
          "type": "string",
          "enum": [
            "ci_failure",
            "drift_detected",
            "scheduled_scan",
            "manual_request"
          ]
        },
        "mode": {
          "type": "string",
          "enum": [
            "hermetic",
            "exploratory"
          ]
        },
        "policy_zone": {
          "type": "string",
          "enum": [
            "infra",
            "orchestrator",
            "scripts",
            "workflows"
          ]
        },
        "pr_template_id": {
          "type": "string",
          "const": "PRT.AUTO_REPAIR.V1"
        },
        "required_checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/required_check"
          },
          "uniqueItems": true,
          "minItems": 1
        },
        "risk_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "blast_radius_estimate"
          ],
          "properties": {
            "blast_radius_estimate": {
              "type": "string",
              "enum": [
                "low",
                "med",
                "high"
              ]
            }
          }
        }
      }
    },
    "cost_weights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens",
        "runtime_seconds",
        "files_changed",
        "risk"
      ],
      "properties": {
        "tokens": {
          "type": "number"
        },
        "runtime_seconds": {
          "type": "number"
        },
        "files_changed": {
          "type": "number"
        },
        "risk": {
          "type": "number"
        }
      }
    },
    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "registry"
      ],
      "properties": {
        "registry": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/invariant_registry_entry"
          }
        }
      }
    }
  }
}
