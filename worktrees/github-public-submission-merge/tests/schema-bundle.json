{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "research-agent.schema-bundle.v1",
  "type": "object",
  "required": [
    "fetch_result",
    "extract_result",
    "chunk_result",
    "vector_result",
    "store_result",
    "deliver_result",
    "notify_payload"
  ],
  "properties": {

    "fetch_result": {
      "$id": "schema.fetch.result",
      "type": "object",
      "required": [
        "request_id",
        "source",
        "retrieved_at",
        "content_type",
        "content_snippet",
        "provenance"
      ],
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9\\-]{8,64}$"
        },
        "source": {
          "type": "object",
          "required": ["url", "tab_id"],
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "tab_id": { "type": "integer" }
          }
        },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "content_type": {
          "type": "string",
          "enum": ["text/html", "text/plain", "application/pdf", "application/json"]
        },
        "content_snippet": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "full_content_pointer": { "type": "string" },
        "http_status": { "type": "integer" },
        "provenance": {
          "type": "object",
          "required": ["fetch_agent", "fetch_method"],
          "properties": {
            "fetch_agent": { "type": "string" },
            "fetch_method": { "type": "string" }
          }
        }
      },
      "additionalProperties": false
    },

    "extract_result": {
      "$id": "schema.extract.result",
      "type": "object",
      "required": [
        "request_id",
        "source_ref",
        "extracted_at",
        "entities",
        "evidence"
      ],
      "properties": {
        "request_id": { "type": "string" },
        "source_ref": {
          "type": "object",
          "required": ["url", "tab_id"],
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "tab_id": { "type": "integer" }
          }
        },
        "extracted_at": { "type": "string", "format": "date-time" },
        "entities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "name", "confidence"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "name": { "type": "string" },
              "aliases": {
                "type": "array",
                "items": { "type": "string" }
              },
              "confidence": {
                "type": "string",
                "enum": ["high", "medium", "low"]
              }
            }
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["snippet", "offset", "provenance"],
            "properties": {
              "snippet": { "type": "string" },
              "offset": { "type": "integer" },
              "provenance": {
                "type": "object",
                "required": ["url", "tab_id"],
                "properties": {
                  "url": { "type": "string", "format": "uri" },
                  "tab_id": { "type": "integer" }
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    },

    "chunk_result": {
      "$id": "schema.chunk.result",
      "type": "object",
      "required": [
        "request_id",
        "chunks",
        "created_at",
        "ingestion_version"
      ],
      "properties": {
        "request_id": { "type": "string" },
        "ingestion_version": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "chunks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["chunk_id", "text", "metadata"],
            "properties": {
              "chunk_id": { "type": "string" },
              "text": { "type": "string", "minLength": 50 },
              "metadata": {
                "type": "object",
                "required": ["source", "confidence"],
                "properties": {
                  "source": {
                    "type": "object",
                    "required": ["url", "tab_id"],
                    "properties": {
                      "url": { "type": "string", "format": "uri" },
                      "tab_id": { "type": "integer" }
                    }
                  },
                  "confidence": {
                    "type": "string",
                    "enum": ["high", "medium", "low"]
                  }
                }
              }
            }
          }
        }
      },
      "additionalProperties": false
    },

    "vector_result": {
      "$id": "schema.vector.result",
      "type": "object",
      "required": ["request_id", "model", "vectors", "generated_at"],
      "properties": {
        "request_id": { "type": "string" },
        "model": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "vectors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["chunk_id", "vector_id", "dimensionality"],
            "properties": {
              "chunk_id": { "type": "string" },
              "vector_id": { "type": "string" },
              "dimensionality": { "type": "integer", "minimum": 1 }
            }
          }
        }
      },
      "additionalProperties": false
    },

    "store_result": {
      "$id": "schema.store.result",
      "type": "object",
      "required": [
        "request_id",
        "object_store_keys",
        "jsonl_key",
        "lineage_hash",
        "stored_at"
      ],
      "properties": {
        "request_id": { "type": "string" },
        "object_store_keys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "jsonl_key": { "type": "string" },
        "lineage_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "stored_at": { "type": "string", "format": "date-time" },
        "counts": {
          "type": "object",
          "properties": {
            "chunks": { "type": "integer" },
            "vectors": { "type": "integer" }
          }
        }
      },
      "additionalProperties": false
    },

    "deliver_result": {
      "$id": "schema.deliver.result",
      "type": "object",
      "required": [
        "request_id",
        "artifacts",
        "manifest_key",
        "delivered_at"
      ],
      "properties": {
        "request_id": { "type": "string" },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["artifact_type", "artifact_key", "sha256"],
            "properties": {
              "artifact_type": { "type": "string" },
              "artifact_key": { "type": "string" },
              "sha256": {
                "type": "string",
                "pattern": "^[A-Fa-f0-9]{64}$"
              }
            }
          }
        },
        "manifest_key": { "type": "string" },
        "delivered_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },

    "notify_payload": {
      "$id": "schema.notify.payload",
      "type": "object",
      "required": [
        "request_id",
        "status",
        "summary",
        "artifacts",
        "lineage_hash",
        "timestamp"
      ],
      "properties": {
        "request_id": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["success", "partial_success", "failed"]
        },
        "summary": { "type": "string" },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["artifact_type", "location", "sha256"],
            "properties": {
              "artifact_type": { "type": "string" },
              "location": { "type": "string" },
              "sha256": {
                "type": "string",
                "pattern": "^[A-Fa-f0-9]{64}$"
              }
            }
          }
        },
        "lineage_hash": {
          "type": "string",
          "pattern": "^[A-Fa-f0-9]{64}$"
        },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  }
}
